# ── Capital.com API ────────────────────────────────────────────────────────────
CAPITAL_API_KEY=your_api_key_here
CAPITAL_EMAIL=your_email@example.com
CAPITAL_PASSWORD=your_password_here
CAPITAL_DEMO=true

# ── Anthropic Claude API ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Notifications (optional) ───────────────────────────────────────────────────
# Get a free topic at https://ntfy.sh or self-host
NTFY_TOPIC=my-trading-bot-alerts
NTFY_SERVER=https://ntfy.sh

# ── Trading parameters ─────────────────────────────────────────────────────────
MAX_TRADES_PER_DAY=1
MAX_RISK_PER_TRADE_PCT=5.0
MIN_CONFIDENCE_SCORE=7
MIN_RISK_REWARD_RATIO=1.5

# ── Kill-switch ────────────────────────────────────────────────────────────────
# Set to false to disable trade execution (analysis still runs)
TRADING_ENABLED=false

# ── Schedule (cron syntax, Mon-Fri 08:00, 12:00, 16:00 CET) ──────────────────
ANALYSIS_SCHEDULE=0 8,12,16 * * 1-5
TRADE_WINDOW_START=09:00
TRADE_WINDOW_END=20:00
TIMEZONE=Europe/Berlin

# ── Advanced ───────────────────────────────────────────────────────────────────
# DATA_DIR=/app/data
# RUN_ONCE=false
