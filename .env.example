# ── Capital.com API ────────────────────────────────────────────────────────────
CAPITAL_API_KEY=your_api_key_here
CAPITAL_EMAIL=your_email@example.com
CAPITAL_PASSWORD=your_password_here
CAPITAL_DEMO=true

# ── DQN-Modell Konfiguration ──────────────────────────────────────────────────
# Pfad zum models/-Ordner (Standard: ./models). Neuestes .pt wird automatisch geladen.
# AI_MODELS_DIR=./models
DQN_SL_PCT=0.003
DQN_TP_PCT=0.005
# DQN_DEVICE=auto

# ── Notifications ──────────────────────────────────────────────────────────────
# Get a free topic at https://ntfy.sh or self-host
NTFY_TOPIC=my-trading-bot-alerts
NTFY_SERVER=https://ntfy.sh

# ── Trading parameters ─────────────────────────────────────────────────────────
MAX_OPEN_POSITIONS=4
MAX_RISK_PER_TRADE_PCT=2.0
MIN_CONFIDENCE_SCORE=8
MIN_RISK_REWARD_RATIO=1.5
MAX_TRADES_PER_DAY=5
COOLDOWN_AFTER_LOSS_MINUTES=60

# ── Position Monitor ──────────────────────────────────────────────────────────
TRAIL_TRIGGER_PCT=1.0
TRAIL_DISTANCE_PCT=0.5
TRAIL_MIN_STEP=5.0
ESCALATION_MAX_PER_DAY=2

# ── Trade confirmation ─────────────────────────────────────────────────────────
# Set to true to require manual approval via ntfy before each trade
TRADE_CONFIRMATION_ENABLED=false
TRADE_CONFIRMATION_TIMEOUT_MINUTES=15
NTFY_CONFIRM_TOPIC=my-trading-bot-confirm

# ── Kill-switch ────────────────────────────────────────────────────────────────
# Set to false to disable trade execution (analysis still runs)
TRADING_ENABLED=false

# ── Schedule ─────────────────────────────────────────────────────────────────
# unified_tick laeuft jede Minute automatisch (kein Cron noetig)
TRADE_WINDOW_START=09:00
TRADE_WINDOW_END=20:00
TIMEZONE=Europe/Berlin

# ── Simulation Engine ────────────────────────────────────────────────────────
# Paper-Trading: jede Minute 24 simulierte Trades (4 Assets x 2 Richtungen x 3 SL/TP)
SIM_ENABLED=false

# ── KI-Analyse (Claude API) ──────────────────────────────────────────────────
# API-Key von https://console.anthropic.com/settings/keys
# Wird für die KI-Simulationsanalyse im Dashboard benötigt (Claude Opus 4.6)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Advanced ───────────────────────────────────────────────────────────────────
DATA_DIR=/app/data
# RUN_ONCE=false
